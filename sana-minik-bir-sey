<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>💌 Sana Bir Mektubum Var</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Comic Sans MS', cursive;
}

body{
background:linear-gradient(135deg,#ffd6e8,#ffeef7);
height:100vh;
display:flex;
justify-content:center;
align-items:center;
overflow:hidden;
}

.container{
position:relative;
text-align:center;
}

.envelope{
width:250px;
height:170px;
background:#ff7aa2;
position:relative;
cursor:pointer;
border-radius:0 0 12px 12px;
transition:0.5s;
margin:auto;
box-shadow:0 15px 30px rgba(0,0,0,.2);
}

.envelope:before{
content:"";
position:absolute;
top:0;
left:0;
border-left:125px solid transparent;
border-right:125px solid transparent;
border-top:90px solid #ff99bb;
transform-origin:top;
transition:1s;
z-index:3;
}

.envelope.open:before{
transform:rotateX(180deg);
}

.letter{
position:absolute;
left:50%;
top:40px;
transform:translateX(-50%);
width:210px;
height:250px;
background:white;
border-radius:20px;
padding:20px;
box-shadow:0 10px 25px rgba(0,0,0,.2);
transition:1s;
z-index:1;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
font-size:23px;
color:#ff4f81;
font-weight:bold;
}

.hide{
transform:translateX(-50%) translateY(140px);
}

.show{
transform:translateX(-50%) translateY(-120px);
}

.hearts{
font-size:35px;
animation:beat 1s infinite;
margin-bottom:15px;
}

@keyframes beat{
50%{
transform:scale(1.2);
}
}

.small{
margin-top:15px;
font-size:17px;
color:#666;
font-weight:normal;
}
</style>

</head>

<body>

<div class="container">

<div id="letter" class="letter hide">

<div class="hearts">
💖💕💖
</div>

<div>
Seni çok özledim balım 🥹❤️
</div>

<div class="small">
"Bu küçük mektup sana kocaman bir sarılma olsun 🪻"
</div>

</div>

<div id="envelope" class="envelope"></div>

</div>

<script>

const envelope=document.getElementById("envelope");
const letter=document.getElementById("letter");

envelope.onclick=()=>{

envelope.classList.add("open");
letter.classList.remove("hide");
letter.classList.add("show");

}

</script>

</body>
</html>
